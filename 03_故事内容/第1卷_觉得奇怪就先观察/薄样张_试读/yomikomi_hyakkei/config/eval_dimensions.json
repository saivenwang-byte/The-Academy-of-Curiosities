{
  "version": "1.0.0",
  "layers": {
    "core": {
      "label": "核心层",
      "dimensions": [
        { "id": "first_impression", "label": "第一印象" },
        { "id": "comprehension_difficulty", "label": "理解难度" },
        { "id": "continue_will", "label": "继续阅读意愿" },
        { "id": "strongest_memory", "label": "最强记忆点" },
        { "id": "biggest_confusion", "label": "最大困惑点" },
        { "id": "recommend_will", "label": "推荐意愿" }
      ],
      "eligible_panels": ["child_experience", "adult_gate", "pro_diagnosis"]
    },
    "child_experience": {
      "label": "儿童体验层",
      "dimensions": [
        { "id": "story_appeal", "label": "故事吸引力" },
        { "id": "character_recognition", "label": "人物辨识与真实感" },
        { "id": "puzzle_engagement", "label": "谜题参与感" },
        { "id": "skip_risk", "label": "跳读风险" },
        { "id": "emotion_experience", "label": "情绪体验" },
        { "id": "illustration_appeal", "label": "插图吸引力" },
        { "id": "next_volume_anticipation", "label": "下一卷期待" }
      ],
      "eligible_panels": ["child_experience"]
    },
    "pro_diagnosis": {
      "label": "专业诊断层",
      "dimensions": [
        { "id": "structure_pace", "label": "结构与节奏" },
        { "id": "mystery_fairness", "label": "推理公平性" },
        { "id": "science_accuracy", "label": "科学准确性" },
        { "id": "jp_campus_authenticity", "label": "日本校园文化真实性" },
        { "id": "age_cognitive_load", "label": "适龄与认知负荷" },
        { "id": "text_image_narrative", "label": "图文叙事" },
        { "id": "serialization_potential", "label": "系列化潜力" },
        { "id": "market_differentiation", "label": "市场差异化" },
        { "id": "production_translation_risk", "label": "生产与翻译风险" }
      ],
      "eligible_panels": ["pro_diagnosis"]
    },
    "adult_gate_extra": {
      "label": "成人把关补充",
      "dimensions": [
        { "id": "safety", "label": "安全与情绪" },
        { "id": "purchase_intent", "label": "购买意愿" },
        { "id": "parent_child_value", "label": "亲子共读价值" },
        { "id": "school_recommend", "label": "学校/图书馆推荐价值" }
      ],
      "eligible_panels": ["adult_gate"]
    }
  },
  "pro_role_scope": {
    "children_editor": {
      "must": ["structure_pace", "serialization_potential", "market_differentiation", "first_impression"],
      "optional": ["mystery_fairness", "text_image_narrative"],
      "na": ["story_appeal", "skip_risk", "purchase_intent"]
    },
    "art_editor": {
      "must": ["text_image_narrative", "illustration_appeal"],
      "optional": ["character_recognition", "first_impression"],
      "na": ["mystery_fairness", "serialization_potential", "purchase_intent"]
    },
    "market_channel": {
      "must": ["market_differentiation", "first_impression", "purchase_intent"],
      "optional": ["serialization_potential"],
      "na": ["science_accuracy", "age_cognitive_load"]
    },
    "critic": {
      "must": ["structure_pace", "mystery_fairness", "market_differentiation"],
      "optional": ["story_appeal"],
      "na": ["purchase_intent", "skip_risk"]
    },
    "reading_cognition": {
      "must": ["age_cognitive_load", "comprehension_difficulty"],
      "optional": ["emotion_experience", "safety"],
      "na": ["market_differentiation", "serialization_potential"]
    },
    "jp_campus_reviewer": {
      "must": ["jp_campus_authenticity"],
      "optional": ["science_accuracy", "structure_pace"],
      "na": ["purchase_intent", "illustration_appeal"]
    }
  },
  "score_scale": { "min": 1, "max": 10, "na_value": null }
}
