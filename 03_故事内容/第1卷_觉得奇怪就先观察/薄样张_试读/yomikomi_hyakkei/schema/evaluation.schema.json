{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://academy-of-curiosities.local/schema/evaluation/v1",
  "title": "YomikomiHyakkei Evaluation",
  "type": "object",
  "required": [
    "persona_id",
    "corpus_id",
    "run_id",
    "mode",
    "reading_experience",
    "comprehension_quiz",
    "structured_scores",
    "behavioral_intent",
    "evidence_citations",
    "uncertainty"
  ],
  "properties": {
    "persona_id": { "type": "string" },
    "corpus_id": { "type": "string" },
    "run_id": { "type": "string" },
    "mode": { "type": "string", "enum": ["dry_run", "live"] },
    "reading_experience": {
      "type": "object",
      "required": ["hook", "dropout_point", "skip_risk_pages", "continue_next", "memorable_character"],
      "properties": {
        "hook": { "type": "string" },
        "dropout_point": { "type": "string" },
        "skip_risk_pages": { "type": "array", "items": { "type": "string" } },
        "continue_next": { "type": "boolean" },
        "memorable_character": { "type": "string" },
        "favorite_moment": { "type": "string" },
        "boring_moment": { "type": "string" }
      }
    },
    "comprehension_quiz": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["question", "answer", "correct"],
        "properties": {
          "question": { "type": "string" },
          "answer": { "type": "string" },
          "correct": { "type": "boolean" }
        }
      }
    },
    "structured_scores": {
      "type": "object",
      "additionalProperties": {
        "oneOf": [
          { "type": "number", "minimum": 1, "maximum": 10 },
          { "type": "null" }
        ]
      }
    },
    "behavioral_intent": {
      "type": "object",
      "properties": {
        "continue_next_chapter": { "type": "string" },
        "recommend_to_friend": { "type": "string" },
        "acquire_mode": { "type": "string", "enum": ["buy", "borrow", "skip", "unsure"] },
        "discuss_mystery": { "type": "boolean" }
      }
    },
    "evidence_citations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["location", "observation"],
        "properties": {
          "location": { "type": "string" },
          "observation": { "type": "string" },
          "severity": { "type": "string", "enum": ["P0", "P1", "note"] }
        }
      }
    },
    "uncertainty": {
      "type": "object",
      "properties": {
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "missing_materials": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" }
      }
    }
  }
}
